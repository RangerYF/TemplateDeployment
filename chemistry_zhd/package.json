{
  "name": "chemistry-anim",
  "private": true,
  "version": "0.1.0",
  "description": "Chemistry education visualization toolkit - single HTML file outputs",
  "scripts": {
    "build": "pnpm build:all",
    "dev:c03": "pnpm --filter @chemistry/c03-equation-balancer dev",
    "dev:c04": "pnpm --filter @chemistry/c04-periodic-table dev",
    "build:c07c09": "node scripts/build-c07-c09-pages.mjs",
    "dev:p01": "pnpm --filter @physics/p01-force-analysis dev",
    "dev:p02": "pnpm --filter @physics/p02-motion-simulation dev",
    "dev:p03": "pnpm --filter @physics/p03-optics dev",
    "dev:p04": "pnpm --filter @physics/p04-circuit-builder dev",
    "dev:p05": "pnpm --filter @physics/p05-harmonic-motion dev",
    "dev:p06": "pnpm --filter @physics/p06-wave-propagation dev",
    "dev:p07": "pnpm --filter @physics/p07-thermodynamics dev",
    "dev:p08": "pnpm --filter @physics/p08-em-fields dev",
    "dev:p09": "pnpm --filter @physics/p09-celestial-mechanics dev",
    "dev:p11": "pnpm --filter @physics/p11-nuclear-physics dev",
    "dev:p12": "pnpm --filter @physics/p12-momentum dev",
    "dev:p13": "pnpm --filter @physics/p13-em-induction dev",
    "dev:p14": "pnpm --filter @physics/p14-mechanical-energy dev",
    "build:c03": "pnpm --filter @chemistry/c03-equation-balancer build",
    "build:c04": "pnpm --filter @chemistry/c04-periodic-table build",
    "build:p01": "pnpm --filter @physics/p01-force-analysis build",
    "build:p02": "pnpm --filter @physics/p02-motion-simulation build",
    "build:p03": "pnpm --filter @physics/p03-optics build",
    "build:p04": "pnpm --filter @physics/p04-circuit-builder build",
    "build:p05": "pnpm --filter @physics/p05-harmonic-motion build",
    "build:p06": "pnpm --filter @physics/p06-wave-propagation build",
    "build:p07": "pnpm --filter @physics/p07-thermodynamics build",
    "build:p08": "pnpm --filter @physics/p08-em-fields build",
    "build:p09": "pnpm --filter @physics/p09-celestial-mechanics build",
    "build:p11": "pnpm --filter @physics/p11-nuclear-physics build",
    "build:p12": "pnpm --filter @physics/p12-momentum build",
    "build:p13": "pnpm --filter @physics/p13-em-induction build",
    "build:p14": "pnpm --filter @physics/p14-mechanical-energy build",
    "build:all": "pnpm -r --workspace-concurrency=1 build && pnpm build:c07c09 && node scripts/copy-portal-index.mjs",
    "test": "vitest",
    "validate": "tsx scripts/validate-output.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "playwright": "^1.58.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-singlefile": "^2.3.0",
    "vitest": "^4.0.18"
  }
}
