{
  "name": "phys-template-p01",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:electric-feedback": "vite --mode electric-feedback --host 0.0.0.0 --port 5173 --strictPort",
    "dev:builder-feedback": "vite --mode builder-feedback --host 0.0.0.0 --port 5173 --strictPort",
    "dev:builder-free-feedback": "vite --mode builder-free-feedback --host 0.0.0.0 --port 5173 --strictPort",
    "dev:p08-standalone": "vite --mode p08-standalone --host 0.0.0.0 --port 5173 --strictPort",
    "build": "tsc --noEmit && vite build",
    "build:electric-feedback": "tsc --noEmit && vite build --mode electric-feedback",
    "build:builder-feedback": "tsc --noEmit && vite build --mode builder-feedback",
    "build:builder-free-feedback": "tsc --noEmit && vite build --mode builder-free-feedback",
    "build:p08-standalone": "tsc --noEmit && vite build --mode p08-standalone",
    "build:vercel": "case \"$VITE_APP_SCOPE\" in builder-feedback) pnpm build:builder-feedback ;; builder-free-feedback) pnpm build:builder-free-feedback ;; p08-standalone) pnpm build:p08-standalone ;; *) pnpm build:electric-feedback ;; esac",
    "lint": "eslint src/ --ext .ts,.tsx",
    "preview": "vite preview",
    "prepare": "husky"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.6.0",
    "lucide-react": "^0.468.0",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-switch": "^1.1.2",
    "@radix-ui/react-select": "^2.1.5",
    "@radix-ui/react-slider": "^1.2.2",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-tabs": "^1.1.3"
  },
  "devDependencies": {
    "vite": "^6.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.0",
    "@types/react": "^18.3.14",
    "@types/react-dom": "^18.3.2",
    "tailwindcss": "^3.4.17",
    "postcss": "^8.4.49",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "husky": "^9.1.7"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
