{
  "id": "P01-FM051-spring-wall",
  "version": "1.0",
  "name": "水平连墙",
  "description": "弹簧一端连墙壁，另一端连物块，分析外力作用下的平衡态",
  "category": "P-01",
  "supportedViewports": ["force"],
  "defaultViewport": "force",
  "displayConfig": {
    "scale": 150,
    "origin": { "x": 200, "y": 400 }
  },
  "entities": [
    {
      "ref": "surface-1",
      "type": "surface",
      "properties": { "length": 7 },
      "transform": { "position": { "x": -1, "y": 0 }, "rotation": 0 },
      "label": "水平面"
    },
    {
      "ref": "pivot-wall",
      "type": "pivot",
      "properties": { "radius": 0.05, "orientation": "left" },
      "transform": { "position": { "x": 0, "y": 0.25 }, "rotation": 0 },
      "label": "墙壁固定点"
    },
    {
      "ref": "spring-1",
      "type": "spring",
      "properties": {
        "stiffness": 100,
        "naturalLength": 1.0,
        "pivotEntityId": "pivot-wall",
        "blockEntityId": "block-A"
      },
      "transform": { "position": { "x": 0, "y": 0.25 }, "rotation": 0 },
      "label": "弹簧"
    },
    {
      "ref": "block-A",
      "type": "block",
      "properties": { "mass": 1, "width": 0.5, "height": 0.5 },
      "transform": { "position": { "x": 1.25, "y": 0 }, "rotation": 0 },
      "label": "物块"
    }
  ],
  "relations": [
    {
      "type": "contact",
      "sourceRef": "block-A",
      "targetRef": "surface-1",
      "properties": { "friction": true }
    },
    {
      "type": "connection",
      "sourceRef": "block-A",
      "targetRef": "pivot-wall",
      "properties": { "connector": "spring-1" }
    }
  ],
  "paramGroups": [
    {
      "key": "spring-params",
      "label": "弹簧",
      "params": [
        {
          "key": "stiffness",
          "label": "劲度系数 k",
          "type": "slider",
          "min": 10,
          "max": 1000,
          "step": 10,
          "default": 100,
          "unit": "N/m",
          "targetEntityId": "spring-1",
          "targetProperty": "stiffness"
        }
      ]
    },
    {
      "key": "block-params",
      "label": "物块",
      "params": [
        {
          "key": "mass",
          "label": "质量 m",
          "type": "slider",
          "min": 0.1,
          "max": 20,
          "step": 0.1,
          "default": 1,
          "unit": "kg",
          "targetEntityId": "block-A",
          "targetProperty": "mass"
        }
      ]
    },
    {
      "key": "force-params",
      "label": "外力",
      "params": [
        {
          "key": "appliedForce",
          "label": "外力 F",
          "type": "slider",
          "min": 0,
          "max": 100,
          "step": 1,
          "default": 5,
          "unit": "N",
          "targetEntityId": "block-A"
        },
        {
          "key": "forceAngle",
          "label": "方向角 θ",
          "type": "slider",
          "min": -180,
          "max": 180,
          "step": 1,
          "default": 0,
          "unit": "°",
          "targetEntityId": "block-A"
        }
      ]
    },
    {
      "key": "surface-params",
      "label": "接触面",
      "params": [
        {
          "key": "friction",
          "label": "摩擦因数 μ",
          "type": "slider",
          "min": 0,
          "max": 1.0,
          "step": 0.01,
          "default": 0,
          "precision": 2
        }
      ]
    }
  ],
  "paramValues": {
    "stiffness": 100,
    "mass": 1,
    "appliedForce": 5,
    "forceAngle": 0,
    "friction": 0
  },
  "solveMode": "analytical",
  "duration": 0,
  "solverQualifier": { "spring": "horizontal-wall" },
  "group": "spring-model",
  "groupLabel": "弹簧模型",
  "groupOrder": 2
}
