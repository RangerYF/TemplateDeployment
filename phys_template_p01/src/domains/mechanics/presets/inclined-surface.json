{
  "id": "P01-FM011-inclined-surface",
  "version": "1.0",
  "name": "斜面受力",
  "description": "分析物块在斜面上的受力与运动，可切换光滑/粗糙、有无外力、有无初速度",
  "category": "P-01",
  "supportedViewports": ["force", "motion"],
  "defaultViewport": "force",
  "displayConfig": {
    "scale": 150,
    "origin": { "x": 450, "y": 500 }
  },
  "entities": [
    {
      "ref": "block-A",
      "type": "block",
      "properties": { "mass": 5, "width": 0.5, "height": 0.5 },
      "transform": { "position": { "x": 0, "y": 0 }, "rotation": 0 },
      "label": "物块"
    },
    {
      "ref": "slope-1",
      "type": "slope",
      "properties": { "angle": 30, "length": 5, "friction": 0.3 },
      "transform": { "position": { "x": -2, "y": -1.5 }, "rotation": 0 },
      "label": "斜面"
    }
  ],
  "relations": [
    {
      "type": "contact",
      "sourceRef": "block-A",
      "targetRef": "slope-1",
      "properties": { "friction": 0.3 }
    }
  ],
  "paramGroups": [
    {
      "key": "block-params",
      "label": "物块",
      "params": [
        {
          "key": "mass",
          "label": "质量 m",
          "type": "slider",
          "min": 0.5,
          "max": 50,
          "step": 0.5,
          "default": 5,
          "unit": "kg",
          "targetEntityId": "block-A",
          "targetProperty": "mass"
        },
        {
          "key": "initialVelocity",
          "label": "初速度 v₀",
          "type": "slider",
          "min": 0,
          "max": 20,
          "step": 0.5,
          "default": 0,
          "unit": "m/s",
          "targetEntityId": "block-A"
        },
        {
          "key": "appliedForce",
          "label": "外力 F",
          "type": "slider",
          "min": 0,
          "max": 500,
          "step": 1,
          "default": 0,
          "unit": "N",
          "targetEntityId": "block-A"
        },
        {
          "key": "forceAngle",
          "label": "力的方向角 α",
          "type": "slider",
          "min": -180,
          "max": 180,
          "step": 1,
          "default": 45,
          "unit": "°",
          "targetEntityId": "block-A"
        }
      ]
    },
    {
      "key": "slope-params",
      "label": "斜面",
      "params": [
        {
          "key": "slopeAngle",
          "label": "斜面角度 θ",
          "type": "slider",
          "min": 5,
          "max": 85,
          "step": 1,
          "default": 30,
          "unit": "°",
          "targetEntityId": "slope-1",
          "targetProperty": "angle"
        },
        {
          "key": "friction",
          "label": "摩擦因数 μ",
          "type": "slider",
          "min": 0,
          "max": 1.0,
          "step": 0.01,
          "default": 0.30,
          "precision": 2,
          "targetEntityId": "slope-1",
          "targetProperty": "friction"
        }
      ]
    }
  ],
  "paramValues": {
    "mass": 5,
    "initialVelocity": 0,
    "appliedForce": 0,
    "forceAngle": 45,
    "slopeAngle": 30,
    "friction": 0.30
  },
  "solveMode": "analytical",
  "duration": 5,
  "solverQualifier": { "surface": "inclined" },
  "eventActions": [
    {
      "eventType": "velocity-zero",
      "action": { "type": "mark-state", "label": "最高点" }
    }
  ]
}
