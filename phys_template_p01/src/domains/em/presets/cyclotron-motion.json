{
  "id": "P02-EM003-cyclotron-motion",
  "version": "1.0",
  "name": "洛伦兹力圆周运动",
  "description": "设置磁场方向、粒子速度与荷质比，观察带电粒子在匀强磁场中的圆周轨迹、半径和周期。",
  "category": "P-08",
  "supportedViewports": ["motion", "force", "field"],
  "defaultViewport": "motion",
  "displayConfig": {
    "scale": 60,
    "origin": { "x": 400, "y": 300 }
  },
  "entities": [
    {
      "ref": "bfield-1",
      "type": "uniform-bfield",
      "properties": {
        "magnitude": 0.5,
        "direction": "into",
        "width": 12,
        "height": 10
      },
      "transform": { "position": { "x": -6, "y": -5 }, "rotation": 0 },
      "label": "匀强磁场区域"
    },
    {
      "ref": "particle-1",
      "type": "point-charge",
      "properties": {
        "charge": 0.5,
        "mass": 0.5,
        "initialVelocity": { "x": 2, "y": 0 },
        "initialSpeed": 2,
        "initialDirectionDeg": 0,
        "radius": 0.12
      },
      "transform": { "position": { "x": -2, "y": -3 }, "rotation": 0 },
      "label": "带电粒子"
    }
  ],
  "relations": [
    {
      "type": "field-effect",
      "sourceRef": "bfield-1",
      "targetRef": "particle-1",
      "properties": {}
    }
  ],
  "paramGroups": [
    {
      "key": "particle-params",
      "label": "粒子参数",
      "params": [
        {
          "key": "charge",
          "label": "电荷量 q",
          "type": "slider",
          "min": -1,
          "max": 1,
          "step": 0.05,
          "default": 0.5,
          "precision": 2,
          "unit": "C",
          "targetEntityId": "particle-1",
          "targetProperty": "charge"
        },
        {
          "key": "mass",
          "label": "质量 m",
          "type": "slider",
          "min": 0.1,
          "max": 2,
          "step": 0.05,
          "default": 0.5,
          "precision": 2,
          "unit": "kg",
          "targetEntityId": "particle-1",
          "targetProperty": "mass"
        },
        {
          "key": "v0",
          "label": "初速度大小 v0",
          "type": "slider",
          "min": 0,
          "max": 6,
          "step": 0.1,
          "default": 2,
          "precision": 1,
          "unit": "m/s",
          "targetEntityId": "particle-1",
          "targetProperty": "initialSpeed"
        },
        {
          "key": "theta",
          "label": "初速度方向 θ",
          "type": "slider",
          "min": 0,
          "max": 360,
          "step": 1,
          "default": 0,
          "precision": 0,
          "unit": "°",
          "targetEntityId": "particle-1",
          "targetProperty": "initialDirectionDeg"
        }
      ]
    },
    {
      "key": "bfield-params",
      "label": "磁场参数",
      "params": [
        {
          "key": "B",
          "label": "磁感应强度 B",
          "type": "slider",
          "min": 0.01,
          "max": 5,
          "step": 0.01,
          "default": 0.5,
          "precision": 2,
          "unit": "T",
          "targetEntityId": "bfield-1",
          "targetProperty": "magnitude"
        },
        {
          "key": "direction",
          "label": "磁场方向",
          "type": "select",
          "options": [
            { "value": "into", "label": "垂直纸面向里 ×" },
            { "value": "out", "label": "垂直纸面向外 ·" }
          ],
          "default": "into",
          "targetEntityId": "bfield-1",
          "targetProperty": "direction"
        }
      ]
    }
  ],
  "paramValues": {
    "charge": 0.5,
    "mass": 0.5,
    "v0": 2,
    "theta": 0,
    "B": 0.5,
    "direction": "into"
  },
  "solveMode": "numerical",
  "duration": 12,
  "solverQualifier": { "interaction": "magnetic" }
}
