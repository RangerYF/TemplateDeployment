{
  "meta": {
    "id": "FM-054",
    "name": "传送带模型",
    "module": "P-01",
    "status": "ready"
  },
  "teaching": {
    "teachingObjective": "通过单一传送带模板，先观察默认水平传送带，再通过右侧属性和初始运动切换倾角、同向/反向速度，比较不同状态下的运动变化。",
    "constructionSteps": [
      "1. 设置场景重力为 (0, -10)。",
      "2. 使用水平传送带作为默认初始状态。",
      "3. 在右侧属性中修改传送带倾角与皮带速度。",
      "4. 在右侧初始运动中设置物块同向或反向初速度。",
      "5. 结合 v-t / vx-t / vy-t 观察不同状态下的变化。"
    ]
  },
  "sceneJsonPath": "/templates/scenes/FM-054.json",
  "commandProgram": {
    "templateId": "FM-054",
    "sceneName": "FM-054 传送带模型",
    "version": "1.0",
    "allowNonZeroInitialVelocity": true,
    "commands": [
      {
        "kind": "setGravity",
        "gravity": {
          "x": 0,
          "y": -10
        }
      },
      {
        "kind": "addBody",
        "ref": "conveyor-main",
        "bodyType": "conveyor",
        "label": "传送带",
        "patch": {
          "position": {
            "x": 0,
            "y": 0.65
          },
          "conveyorWidth": 8,
          "conveyorHeight": 1.1,
          "beltSpeed": 2.5
        }
      },
      {
        "kind": "snapTo",
        "bodyRef": "conveyor-main",
        "targetBodyRefs": [
          "ground"
        ],
        "threshold": 4
      },
      {
        "kind": "addBody",
        "ref": "block-main",
        "bodyType": "block",
