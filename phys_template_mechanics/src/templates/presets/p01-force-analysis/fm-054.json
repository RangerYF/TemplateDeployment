          },
          "width": 0.8,
          "height": 0.6,
          "mass": 1.2,
          "friction": 0.4,
          "restitution": 0,
          "fixedRotation": true,
          "initialVelocity": {
            "x": 0,
            "y": 0
          }
        }
      },
      {
        "kind": "snapTo",
        "bodyRef": "block-main",
        "targetBodyRefs": [
