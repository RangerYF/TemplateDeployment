  "teaching": {
    "teachingObjective": "通过“绳连水平面两物体”模板，让学生建立现象、受力与运动规律之间的对应。",
    "constructionSteps": [
      "1. 设置场景重力为 (0, -10)。",
      "2. 添加物体 block-left（block）。",
      "3. 将物体 block-left 吸附到 ground。",
      "4. 添加物体 block-right（block）。",
      "5. 将物体 block-right 吸附到 ground。",
      "6. 添加约束 rope-main（rope），连接 block-left 与 block-right。",
      "7. 给物体 block-left 添加外力 drive-force。"
    ]
  },
  "sceneJsonPath": "/templates/scenes/FM-031.json",
  "commandProgram": {
    "templateId": "FM-031",
    "sceneName": "FM-031 绳连水平面两物体",
    "version": "1.0",
