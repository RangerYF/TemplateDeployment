        "patch": {
          "position": {
            "x": 2.4,
            "y": 2.225
          },
          "width": 0.75,
          "height": 0.75,
          "mass": 0.6,
          "friction": 0.6,
          "restitution": 0,
          "fixedRotation": true
        }
      },
      {
        "kind": "snapTo",
        "bodyRef": "slider-main",
        "targetBodyRefs": [
          "disk-main"
        ],
        "threshold": 1.2
      }
    ]
  }
}
