{
  "meta": {
    "id": "FM-041",
    "name": "圆盘摩擦模型",
    "module": "P-01",
    "status": "planned"
  },
  "teaching": {
    "teachingObjective": "通过圆盘摩擦模型的侧视图，观察圆盘上滑块随盘转动时的受力关系，重点理解静摩擦力提供向心力，并比较不同角速度下未打滑、临界与将打滑三种状态。",
    "constructionSteps": [
      "1. 设置场景重力为 (0, -10)。",
      "2. 添加转轴 axle-main，并在其上方放置圆盘侧视图 disk-main。",
      "3. 添加盘上滑块 slider-main，作为随圆盘转动的研究对象。",
      "4. 在右侧教学参数中调节角速度 ω，观察滑块的 G、N 和指向圆心的静摩擦力 f静。",
      "5. 结合未打滑、临界、将打滑三种状态，比较所需向心力与最大静摩擦力。"
    ]
  },
  "sceneJsonPath": "/templates/scenes/FM-041.json",
  "commandProgram": {
    "templateId": "FM-041",
    "sceneName": "FM-041 圆盘摩擦模型",
    "version": "1.0",
    "allowCustomBodySize": true,
    "commands": [
      {
