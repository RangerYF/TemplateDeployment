        "gravity": {
          "x": 0,
          "y": -10
        }
      },
      {
        "kind": "addBody",
        "ref": "axle-main",
        "bodyType": "wall",
        "label": "转轴",
        "patch": {
          "position": {
            "x": 0,
            "y": 0.7
          },
          "wallWidth": 0.18,
          "wallHeight": 1.4
        }
      },
      {
        "kind": "addBody",
        "ref": "disk-main",
        "bodyType": "block",
        "label": "圆盘",
        "patch": {
          "position": {
            "x": 0,
            "y": 1.625
          },
          "width": 7.2,
          "height": 0.45,
          "isStatic": true,
          "mass": 6,
          "friction": 0.6,
          "restitution": 0,
          "fixedRotation": true,
          "initialVelocity": {
            "x": 2,
            "y": 0
          }
        }
      },
      {
        "kind": "addBody",
        "ref": "slider-main",
        "bodyType": "block",
