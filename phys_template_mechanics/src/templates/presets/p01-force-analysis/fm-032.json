{
  "meta": {
    "id": "FM-032",
    "name": "绳连斜面-悬挂",
    "module": "P-01",
    "status": "ready"
  },
  "teaching": {
    "teachingObjective": "通过“绳连斜面-悬挂”模板，让学生建立现象、受力与运动规律之间的对应。",
    "constructionSteps": [
      "1. 设置场景重力为 (0, -10)。",
      "2. 添加物体 slope-main（slope）。",
      "3. 将物体 slope-main 吸附到 ground。",
      "4. 添加物体 block-slope（block）。",
      "5. 将物体 block-slope 吸附到 slope-main。",
      "6. 添加物体 pulley-main（pulley-mount）。",
      "7. 添加物体 block-hanging（block）。",
      "8. 添加约束 pulley-rope（pulley），连接 block-slope 与 block-hanging。"
    ]
  },
  "sceneJsonPath": "/templates/scenes/FM-032.json",
  "commandProgram": {
    "templateId": "FM-032",
    "sceneName": "FM-032 绳连斜面-悬挂",
    "version": "1.0",
    "commands": [
      {
        "kind": "setGravity",
        "gravity": {
          "x": 0,
          "y": -10
        }
      },
      {
        "kind": "addBody",
        "ref": "slope-main",
        "bodyType": "slope",
        "patch": {
          "position": {
            "x": -2.4,
            "y": 0.15
          },
          "baseLength": 4.8,
          "slopeHeight": 2.4,
          "isStatic": true,
          "fixedRotation": true,
          "friction": 0.2
        }
      },
      {
        "kind": "snapTo",
        "bodyRef": "slope-main",
        "targetBodyRefs": [
          "ground"
        ],
        "threshold": 8
      },
      {
        "kind": "addBody",
        "ref": "block-slope",
        "bodyType": "block",
        "patch": {
          "position": {
            "x": -2,
            "y": 2.2
          },
          "width": 0.8,
          "height": 0.6,
          "mass": 1,
          "friction": 0.2,
          "restitution": 0,
          "fixedRotation": true
        }
      },
      {
        "kind": "snapTo",
        "bodyRef": "block-slope",
        "targetBodyRefs": [
          "slope-main"
        ],
        "threshold": 2.2
      },
      {
        "kind": "addBody",
        "ref": "pulley-main",
        "bodyType": "pulley-mount",
        "patch": {
          "position": {
            "x": 0.6,
            "y": 2.7
          },
          "pulleyRadius": 0.28
        }
      },
      {
        "kind": "addBody",
        "ref": "block-hanging",
        "bodyType": "block",
        "patch": {
          "position": {
            "x": 2.1,
            "y": 1.2
          },
          "width": 0.8,
          "height": 0.6,
          "mass": 1.1,
          "friction": 0.2,
          "restitution": 0,
          "fixedRotation": true
        }
      },
      {
        "kind": "addJoint",
        "ref": "pulley-rope",
        "jointType": "pulley",
        "bodyRefA": "block-slope",
        "bodyRefB": "block-hanging",
        "pulleyMountRef": "pulley-main",
        "anchorA": {
          "x": 0,
          "y": 0.25
        },
        "anchorB": {
          "x": 0,
          "y": 0.25
        },
        "patch": {
          "ratio": 1
        }
      }
    ]
  }
}
