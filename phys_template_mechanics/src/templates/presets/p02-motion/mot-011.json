{
  "meta": {
    "id": "MOT-011",
    "name": "斜面下滑",
    "module": "P-02",
    "status": "ready"
  },
  "teaching": {
    "teachingObjective": "通过“斜面下滑”模板，让学生观察重力沿斜面分量导致的匀加速运动。",
    "constructionSteps": [
      "1. 设置场景重力为 (0, -10)。",
      "2. 添加物体 slope-main（slope）。",
      "3. 将物体 slope-main 吸附到 ground。",
      "4. 添加物体 block-main（block）。",
      "5. 将物体 block-main 吸附到 slope-main。"
    ]
  },
  "sceneJsonPath": "/templates/scenes/MOT-011.json",
  "commandProgram": {
    "templateId": "MOT-011",
    "sceneName": "MOT-011 斜面下滑",
    "version": "1.0",
    "commands": [
      {
        "kind": "setGravity",
        "gravity": {
          "x": 0,
          "y": -10
        }
      },
      {
        "kind": "addBody",
        "ref": "slope-main",
        "bodyType": "slope",
        "patch": {
          "position": {
            "x": -0.4,
            "y": 0.2
          },
          "baseLength": 5.6,
          "slopeHeight": 2.8,
          "isStatic": true,
          "fixedRotation": true,
          "friction": 0.2
        }
      },
      {
        "kind": "snapTo",
        "bodyRef": "slope-main",
        "targetBodyRefs": [
          "ground"
        ],
        "threshold": 8
      },
      {
        "kind": "addBody",
        "ref": "block-main",
        "bodyType": "block",
        "patch": {
          "position": {
            "x": -1.8,
            "y": 2.7
          },
          "width": 0.8,
          "height": 0.6,
          "mass": 1,
          "friction": 0.08,
          "restitution": 0,
          "fixedRotation": true
        }
      },
      {
        "kind": "snapTo",
        "bodyRef": "block-main",
        "targetBodyRefs": [
          "slope-main"
        ],
        "threshold": 2.5
      }
    ]
  }
}
