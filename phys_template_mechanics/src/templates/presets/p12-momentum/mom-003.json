  "teaching": {
    "teachingObjective": "通过部分弹性碰撞模板，对比恢复系数小于 1 时动量守恒与动能损失并存的现象。",
    "constructionSteps": [
      "1. 设置场景重力为 (0, -10)。",
      "2. 添加球体 ball-left 与 ball-right，并吸附到 ground。",
      "3. 设置 ball-left 初速度为向右，ball-right 初速度为 0。",
      "4. 将两球恢复系数设为 0.5，构造部分弹性碰撞。"
    ]
  },
  "sceneJsonPath": "/templates/scenes/MOM-003.json",
  "commandProgram": {
