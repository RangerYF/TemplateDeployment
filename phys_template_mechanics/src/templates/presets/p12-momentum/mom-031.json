{
  "meta": {
    "id": "MOM-031",
    "name": "人在船上行走",
    "module": "P-12",
    "status": "ready"
  },
  "teaching": {
    "teachingObjective": "通过“人-船”近似模型，观察系统总动量接近零时主体与承载体的反向运动关系。",
    "constructionSteps": [
      "1. 设置场景重力为 (0, 0)。",
      "2. 添加更长的 boat-main（船）和小质量 person-main（人）。",
      "3. 设置两者初速度方向相反，并满足总动量近似抵消。",
      "4. 运行仿真观察相对位移与反向运动。"
    ]
  },
  "sceneJsonPath": "/templates/scenes/MOM-031.json",
  "commandProgram": {
    "templateId": "MOM-031",
    "sceneName": "MOM-031 人在船上行走",
    "version": "1.0",
    "allowNonZeroInitialVelocity": true,
    "allowCustomBodySize": true,
    "commands": [
      {
        "kind": "setGravity",
        "gravity": {
          "x": 0,
          "y": 0
        }
      },
      {
        "kind": "addBody",
        "ref": "boat-main",
        "bodyType": "block",
        "patch": {
          "position": {
            "x": 0,
            "y": 2.2
          },
          "width": 16,
          "height": 0.6,
          "mass": 4,
          "friction": 0.05,
          "restitution": 0,
          "fixedRotation": true,
          "initialVelocity": {
            "x": -0.4,
            "y": 0
          }
        }
      },
      {
        "kind": "addBody",
        "ref": "person-main",
        "bodyType": "block",
        "patch": {
          "position": {
            "x": -1,
            "y": 2.8
          },
          "mass": 1,
          "friction": 0.2,
          "restitution": 0,
          "fixedRotation": true,
          "initialVelocity": {
            "x": 1.6,
            "y": 0
          }
        }
      },
      {
        "kind": "snapTo",
        "bodyRef": "person-main",
        "targetBodyRefs": [
          "boat-main"
        ],
        "threshold": 1.2
      }
    ]
  }
}
