  "teaching": {
    "teachingObjective": "通过滑块碰撞后滑行模板，分段观察碰撞阶段动量关系与碰后摩擦耗散。",
    "constructionSteps": [
      "1. 设置场景重力为 (0, -10)。",
      "2. 添加有限平台 platform-main，并在平台上放置两个滑块。",
      "3. 设置 block-a 初速度使其追碰 block-b。",
      "4. 观察碰撞阶段与碰后平台摩擦滑行阶段的分段变化。"
    ]
  },
  "sceneJsonPath": "/templates/scenes/MOM-013.json",
